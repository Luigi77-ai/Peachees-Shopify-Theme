<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" data-theme="light">

<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#f7f3ee">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {%- endunless -%}

  <!-- Google Fonts Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {% comment %} <!-- Base CSS --> {% endcomment %}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

  {% comment %} <!-- Custom Inline CSS for Peachees theme --> {% endcomment %}
  <style>
    :root {
      --bg: #f7f3ee;
      --surface: #fbf8f4;
      --surface-2: #efe7de;
      --text: #181513;
      --muted: #74685e;
      --line: rgba(24, 21, 19, 0.12);
      --accent: #c98f79;
      --accent-deep: #b17763;
      --white: #ffffff;
      --black: #1a1a1a;

      --radius-sm: 10px;
      --radius-md: 18px;
      --radius-lg: 28px;
      --shadow: 0 24px 70px rgba(53, 38, 29, 0.08);

      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --space-10: 40px;
      --space-12: 48px;
      --space-16: 64px;
      --space-20: 80px;

      --text-xs: clamp(0.75rem, 0.72rem + 0.2vw, 0.875rem);
      --text-sm: clamp(0.875rem, 0.82rem + 0.25vw, 1rem);
      --text-base: clamp(1rem, 0.9rem + 0.5vw, 1.125rem);
      --text-lg: clamp(1.125rem, 1.0rem + 0.75vw, 1.25rem);
      --text-xl: clamp(1.5rem, 1.25rem + 1.25vw, 2rem);
      --text-2xl: clamp(2rem, 1.5rem + 2.5vw, 3rem);
      --text-3xl: clamp(2.5rem, 1.75rem + 3.75vw, 4rem);
      --text-4xl: clamp(3rem, 2rem + 5vw, 5rem);

      --fw-reg: 400;
      --fw-med: 500;
      --fw-sb: 600;
      --fw-bd: 700;
      --fw-xb: 800;
      --fw-blk: 900;

      --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font-sans);
      font-size: var(--text-base);
      color: var(--text);
      background: var(--bg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      letter-spacing: -0.01em;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; height: auto; display: block; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-6); }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-md);
      font-weight: var(--fw-sb);
      font-size: var(--text-sm);
      letter-spacing: 0.02em;
      transition: all 0.2s ease;
      border: none;
      cursor: pointer;
    }
    .btn-primary {
      background: var(--accent);
      color: var(--white);
    }
    .btn-primary:hover {
      background: var(--accent-deep);
    }
    .btn-outline {
      background: transparent;
      color: var(--white);
      border: 1.5px solid rgba(255,255,255,0.3);
    }
    .btn-outline:hover {
      border-color: var(--white);
      background: rgba(255,255,255,0.08);
    }
    .btn-dark {
      background: var(--black);
      color: var(--white);
    }
    .btn-dark:hover {
      background: var(--accent);
    }

    /* Skip link */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 0;
      background: var(--text);
      color: var(--white);
      padding: var(--space-2) var(--space-4);
      z-index: 9999;
      transition: top 0.2s;
    }
    .skip-link:focus { top: 0; }
  </style>

</head>

<body id="top">

  <a class="skip-link" href="#main-content">Skip to content</a>

  {% section 'header-nav' %}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

</body>
</html>
