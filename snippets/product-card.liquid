{%- comment -%}
  Peachees Product Card
  Renders a single product with image, title, price, badge, and link
  Context: product object available
{%- endcomment -%}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card-link">
    <div class="product-image-wrapper">
      {%- if product.featured_media -%}
        <img
          srcset="
            {{- product.featured_media | image_url: width: 400 -
            }} 400w,
            {{- product.featured_media | image_url: width: 600 -
            }} 600w,
            {{- product.featured_media | image_url: width: 800 -
            }} 800w
          "
          sizes="(max-width: 768px) 90vw, (max-width: 1200px) 30vw, 400px"
          src="{{ product.featured_media | image_url: width: 600 }}"
          alt="{{ product.featured_media.alt | escape }}"
          loading="lazy"
          width="600"
          height="800"
        >
      {%- else -%}
        <div class="product-placeholder">
          <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="M21 15l-5-5L5 21" />
          </svg>
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-badge sale">Sale</span>
      {%- elsif product.available == false -%}
        <span class="product-badge sold-out">Sold Out</span>
      {%- elsif product.tags contains "New" -%}
        <span class="product-badge new">New</span>
      {%- elsif product.tags contains "Best Seller" -%}
        <span class="product-badge best-seller">Best Seller</span>
      {%- endif -%}

      <div class="product-card-hover">
        <span class="hover-text">View details</span>
      </div>
    </div>

    <div class="product-info">
      {%- if product.tags contains "New" -%}
        <span class="product-tag">NEW</span>
      {%- endif -%}
      <h3 class="product-title">{{ product.title }}</h3>
      {%- if product.description -%}
        <p class="product-desc">{{ product.description | strip_html | truncate: 100 }}</p>
      {%- endif -%}
      <div class="product-price">
        {%- if product.compare_at_price > product.price -%}
          <span class="price-sale">{{ product.price | money }}</span>
          <span class="price-compare">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span class="price-regular">{{ product.price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>
</div>

<style>
  .product-card {
    position: relative;
  }
  .product-card-link {
    display: block;
    color: inherit;
  }
  .product-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--surface-2);
    aspect-ratio: 3 / 4;
  }
  .product-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .product-card:hover .product-image-wrapper img {
    transform: scale(1.03);
  }
  .product-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
  }
  .product-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: var(--space-1) var(--space-3);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    z-index: 2;
  }
  .product-badge.new {
    background: var(--surface-2);
    color: var(--text);
  }
  .product-badge.best-seller {
    background: var(--text);
    color: var(--white);
  }
  .product-badge.sale {
    background: var(--accent);
    color: var(--white);
  }
  .product-badge.sold-out {
    background: var(--muted);
    color: var(--white);
  }
  .product-card-hover {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .product-card:hover .product-card-hover {
    opacity: 1;
  }
  .hover-text {
    color: var(--white);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .product-info {
    padding: var(--space-4) var(--space-1) var(--space-2);
  }
  .product-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-2);
  }
  .product-title {
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-1);
  }
  .product-desc {
    font-size: var(--text-xs);
    color: var(--muted);
    margin: 0 0 var(--space-2);
    line-height: 1.5;
  }
  .product-price {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .price-sale {
    color: var(--accent-deep);
  }
  .price-compare {
    color: var(--muted);
    text-decoration: line-through;
    font-weight: 400;
  }
  .price-regular {
    color: var(--text);
  }
</style>
