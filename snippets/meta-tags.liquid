{%- comment -%}
  Peachees Meta Tags
  SEO meta tags, Open Graph, Twitter Cards, and JSON-LD
{%- endcomment -%}

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description
-%}

<link rel="canonical" href="{{ canonical_url }}" />

{%- if settings.favicon != blank -%}
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" />
{%- endif -%}

<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="format-detection" content="telephone=no" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="theme-color" content="{{ settings.color_background | default: '#f7f3ee' }}" />

{%- if og_title -%}
  <meta property="og:title" content="{{ og_title | strip_html | escape }}" />
{%- endif -%}
{%- if og_description -%}
  <meta property="og:description" content="{{ og_description | strip_html | escape }}" />
{%- endif -%}
<meta property="og:type" content="{% if template contains 'product' %}product{% elsif template contains 'collection' %}product.group{% else %}website{% endif %}" />
<meta property="og:url" content="{{ canonical_url }}" />
<meta property="og:site_name" content="{{ shop.name | escape }}" />
<meta property="og:locale" content="{{ request.locale.iso_code }}" />

{%- if template contains 'product' and product.featured_media.preview_image -%}
  <meta property="og:image" content="http:{{ product.featured_media.preview_image | image_url: width: 1200 }}" />
  <meta property="og:image:secure_url" content="https:{{ product.featured_media.preview_image | image_url: width: 1200 }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
{%- elsif settings.share_image -%}
  <meta property="og:image" content="http:{{ settings.share_image | image_url: width: 1200 }}" />
  <meta property="og:image:secure_url" content="https:{{ settings.share_image | image_url: width: 1200 }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
{%- endif -%}

{%- if template contains 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip }}" />
  <meta property="og:price:currency" content="{{ shop.currency }}" />
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}" />
  {%- for variant in product.variants limit: 1 -%}
    <meta property="product:condition" content="new" />
    <meta property="product:brand" content="{{ shop.name | escape }}" />
    <meta property="product:product_link" content="{{ canonical_url }}" />
    {%- if variant.price > 0 -%}
      <meta property="product:price:amount" content="{{ variant.price | money_without_currency | strip }}" />
      <meta property="product:price:currency" content="{{ shop.currency }}" />
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ og_title | strip_html | escape }}" />
{%- if og_description -%}
  <meta name="twitter:description" content="{{ og_description | strip_html | escape }}" />
{%- endif -%}

{%- if template contains 'product' and product.featured_media.preview_image -%}
  <meta name="twitter:image" content="https:{{ product.featured_media.preview_image | image_url: width: 1200 }}" />
{%- elsif settings.share_image -%}
  <meta name="twitter:image" content="https:{{ settings.share_image | image_url: width: 1200 }}" />
{%- endif -%}

{%- liquid
  assign current_tags = false
  if current_tags
    assign current_tags = true
  endif
-%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "sameAs": [
      {% if settings.social_instagram %}"{{ settings.social_instagram }}",{% endif %}
      {% if settings.social_facebook %}"{{ settings.social_facebook }}",{% endif %}
      {% if settings.social_twitter %}"{{ settings.social_twitter }}"{% endif %}
    ]
  }
</script>

{%- if product -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ canonical_url | prepend: shop.url | json }},
      "image": {{ product.featured_media | image_url: width: 800 | prepend: 'https:' | json }},
      "description": {{ product.description | strip_html | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ shop.name | json }}
      },{% if product.available %}
      "availability": "http://schema.org/InStock",{% else %}
      "availability": "http://schema.org/OutOfStock",{% endif %}
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ shop.currency | json }},
        "price": {{ product.price | money_without_currency | json }},
        "url": {{ canonical_url | prepend: shop.url | json }},
        "itemCondition": "http://schema.org/NewCondition",
        "priceValidUntil": "{{ 'now' | date: "%Y-12-31" }}"
      }
    }
  </script>
{%- endif -%}
