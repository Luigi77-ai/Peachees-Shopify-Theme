{%- comment -%}
  Peachees Header Navigation
  Logo + Nav Links (Collection, Story, Lookbook, Next Drop) + Cart icon
{%- endcomment -%}

<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="{{ routes.root_url }}" class="brand-link" aria-label="Peachees Fit home">
      {% if section.settings.logo != blank %}
        <img
          srcset="{{- section.settings.logo | image_url: width: 140 -
          }} 1x, {{- section.settings.logo | image_url: width: 280 -
          }} 2x"
          src="{{ section.settings.logo | image_url: width: 140 }}"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          width="120"
          loading="eager"
        >
      {% else %}
        <span class="brand-text">PEACHEES <small>FIT</small></span>
      {% endif %}
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        <li><a href="{{ section.settings.collection_url | default: routes.collections_url }}">{{ section.settings.collection_label | default: 'Collection' }}</a></li>
        {% if section.settings.story_url != blank %}
          <li><a href="{{ section.settings.story_url }}">{{ section.settings.story_label | default: 'Story' }}</a></li>
        {% endif %}
        <li><a href="{{ section.settings.lookbook_url | default: routes.collections_url }}">{{ section.settings.lookbook_label | default: 'Lookbook' }}</a></li>
        {% if section.settings.next_drop_url != blank %}
          <li><a href="{{ section.settings.next_drop_url }}">{{ section.settings.next_drop_label | default: 'Next Drop' }}</a></li>
        {% endif %}
      </ul>
    </nav>

    <div class="header-actions">
      {%- if shop.customer_accounts_enabled -%}
        {%- if customer -%}
          <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <circle cx="12" cy="8" r="4" />
              <path d="M6 20c0-3.3 2.7-6 6-6s6 2.7 6 6" />
            </svg>
          </a>
        {%- else -%}
          <a class="icon-btn" href="{{ routes.account_login_url }}" aria-label="Log in">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <circle cx="12" cy="8" r="4" />
              <path d="M6 20c0-3.3 2.7-6 6-6s6 2.7 6 6" />
            </svg>
          </a>
        {%- endif -%}
      {%- endif -%}

      <a class="icon-btn cart-link" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path d="M6 6h13l-1.5 9.5a2 2 0 0 1-2 1.6H9.5a2 2 0 0 1-2-1.6L6 6Z" />
          <circle cx="9" cy="20" r="1.5" />
          <circle cx="17.5" cy="20" r="1.5" />
          <path d="M6 6 5 3H2" />
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <button class="menu-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <ul class="mobile-nav-list">
      <li><a href="{{ section.settings.collection_url | default: routes.collections_url }}">{{ section.settings.collection_label | default: 'Collection' }}</a></li>
      {% if section.settings.story_url != blank %}
        <li><a href="{{ section.settings.story_url }}">{{ section.settings.story_label | default: 'Story' }}</a></li>
      {% endif %}
      <li><a href="{{ section.settings.lookbook_url | default: routes.collections_url }}">{{ section.settings.lookbook_label | default: 'Lookbook' }}</a></li>
      {% if section.settings.next_drop_url != blank %}
        <li><a href="{{ section.settings.next_drop_url }}">{{ section.settings.next_drop_label | default: 'Next Drop' }}</a></li>
      {% endif %}
      <li><a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a></li>
    </ul>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }
  .brand-link { display: flex; align-items: center; }
  .brand-text {
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .brand-text small {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-left: var(--space-1);
  }
  .primary-nav { display: none; }
  @media (min-width: 768px) {
    .primary-nav { display: block; }
    .menu-toggle { display: none; }
  }
  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-8);
  }
  .nav-list a {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text);
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .nav-list a:hover { opacity: 1; }
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    position: relative;
  }
  .icon-btn:hover { background: var(--surface-2); }
  .cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background: var(--accent);
    color: var(--white);
    font-size: 11px;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .menu-toggle .bar {
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: 0.3s;
  }
  .mobile-menu {
    background: var(--bg);
    border-top: 1px solid var(--line);
    padding: var(--space-4) var(--space-6);
  }
  .mobile-nav-list { list-style: none; margin: 0; padding: 0; }
  .mobile-nav-list li { border-bottom: 1px solid var(--line); }
  .mobile-nav-list a {
    display: block;
    padding: var(--space-4) 0;
    font-size: var(--text-base);
    font-weight: 500;
  }
</style>

<script>
  (function() {
    const toggle = document.querySelector('.menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', function() {
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!expanded));
        menu.hidden = expanded;
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Header Navigation",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "url",
      "id": "collection_url",
      "label": "Collection URL"
    },
    {
      "type": "text",
      "id": "collection_label",
      "label": "Collection label",
      "default": "Collection"
    },
    {
      "type": "url",
      "id": "story_url",
      "label": "Story URL"
    },
    {
      "type": "text",
      "id": "story_label",
      "label": "Story label",
      "default": "Story"
    },
    {
      "type": "url",
      "id": "lookbook_url",
      "label": "Lookbook URL"
    },
    {
      "type": "text",
      "id": "lookbook_label",
      "label": "Lookbook label",
      "default": "Lookbook"
    },
    {
      "type": "url",
      "id": "next_drop_url",
      "label": "Next Drop URL"
    },
    {
      "type": "text",
      "id": "next_drop_label",
      "label": "Next Drop label",
      "default": "Next Drop"
    }
  ]
}
{% endschema %}
