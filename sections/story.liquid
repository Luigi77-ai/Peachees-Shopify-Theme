{%- comment -%}
  Peachees Brand Story Section
  Two-column layout: image/video on one side, text on the other
{%- endcomment -%}

<section class="story-section" id="story" aria-labelledby="story-title">
  <div class="container">
    <div class="story-grid">
      <div class="story-media">
        {%- if section.settings.media_type == 'video' and section.settings.video_url != blank -%}
          <div class="story-video-wrapper">
            <video
              src="{{ section.settings.video_url }}"
              autoplay
              muted
              loop
              playsinline
              class="story-video"
            ></video>
          </div>
        {%- elsif section.settings.image != blank -%}
          <img
            srcset="
              {{- section.settings.image | image_url: width: 600 -
              }} 600w,
              {{- section.settings.image | image_url: width: 900 -
              }} 900w,
              {{- section.settings.image | image_url: width: 1200 -
              }} 1200w
            "
            sizes="(max-width: 768px) 90vw, 45vw"
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            loading="lazy"
            class="story-image"
          >
        {%- else -%}
          <div class="story-placeholder">
            <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="M21 15l-5-5L5 21" />
            </svg>
          </div>
        {%- endif -%}
      </div>

      <div class="story-content">
        {%- if section.settings.label != blank -%}
          <span class="section-label">{{ section.settings.label | escape }}</span>
        {%- endif -%}

        <h2 id="story-title" class="story-heading">{{ section.settings.heading | escape }}</h2>

        {%- if section.settings.text != blank -%}
          <div class="story-text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .story-section {
    padding: var(--space-20) 0;
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }
  @media (max-width: 768px) {
    .story-grid { grid-template-columns: 1fr; gap: var(--space-10); }
  }
  .story-media {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-2);
  }
  .story-image,
  .story-video-wrapper {
    width: 100%;
    height: 100%;
    display: block;
  }
  .story-image {
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .story-video-wrapper {
    position: relative;
    overflow: hidden;
  }
  .story-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    background: var(--surface-2);
  }
  .section-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-4);
  }
  .story-heading {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 var(--space-6);
  }
  @media (max-width: 768px) {
    .story-heading { font-size: var(--text-xl); }
  }
  .story-text {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.8;
  }
  .story-text p { margin: 0 0 var(--space-4); }
  .story-text p:last-child { margin: 0; }
</style>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Brand Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury softness with gym-girl confidence."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>This concept blends a calm, elevated layout with a stronger brand-forward identity inspired by the Peachees Fit aesthetic.</p><p>Warm neutrals, spacious composition, and strong product imagery make the shop feel more boutique than mass retail.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story image"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
