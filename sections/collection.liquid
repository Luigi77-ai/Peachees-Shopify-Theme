{%- comment -%}
  Peachees Collection Section
  Product grid with editable heading, description, and product selection
{%- endcomment -%}

<section class="collection-section" id="collection" aria-labelledby="collection-title">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-label">{{ section.settings.label | escape }}</span>
      {%- endif -%}
      <h2 id="collection-title" class="section-heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="section-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- liquid
        assign collection_handle = section.settings.collection.handle
        if section.settings.collection != blank
          assign products = section.settings.collection.products
        else
          assign products = collections.all.products
        endif
        if products.size == 0
          assign products = section.settings.products
        endif
      -%}

      {%- for product in products limit: section.settings.products_per_page -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        {%- comment -%} Fallback product cards if no products assigned {%- endcomment -%}
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign badge = 'NEW'
                assign title = 'Luna Sculpt Set'
                assign price = '$89.00'
                assign desc = 'Second-skin support with clean seams and a flattering high-rise fit.'
              when 2
                assign badge = 'BEST SELLER'
                assign title = 'Halo One Piece'
                assign price = '$98.00'
                assign desc = 'A sleek one-piece look made to contour softly and move effortlessly.'
              when 3
                assign title = 'Cloud Flare Pant'
                assign price = '$79.00'
                assign desc = 'High-waisted flare styling with lounge softness and a polished silhouette.'
            endcase
          -%}
          <a href="#drop" class="product-card">
            <div class="product-image-wrapper">
              <div class="product-placeholder">
                <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <circle cx="8.5" cy="8.5" r="1.5" />
                  <path d="M21 15l-5-5L5 21" />
                </svg>
              </div>
              {%- if badge != blank -%}
                <span class="product-badge {% if badge == 'NEW' %}new{% elsif badge == 'BEST SELLER' %}best-seller{% endif %}">{{ badge }}</span>
              {%- endif -%}
            </div>
            <div class="product-info">
              <h3 class="product-title">{{ title }}</h3>
              <p class="product-desc">{{ desc }}</p>
              <div class="product-price"><span class="price-regular">{{ price }}</span></div>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collection-section {
    padding: var(--space-20) 0;
  }
  .section-header {
    text-align: center;
    max-width: 520px;
    margin: 0 auto var(--space-12);
  }
  .section-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-4);
  }
  .section-heading {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 var(--space-4);
  }
  @media (max-width: 768px) {
    .section-heading { font-size: var(--text-xl); }
  }
  .section-desc {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .product-grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three essentials, styled like a boutique drop."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shop the latest Peachees Fit pieces with campaign-quality presentation. Each item is designed to feel like a curated drop, not a catalog."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{% endschema %}
