{%- comment -%}
  Peachees Hero Section
  Full-width hero with background image, overlay text, badge, headline, subtitle, and CTAs
{%- endcomment -%}

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-bg">
    {%- if section.settings.hero_image != blank -%}
      <img
        srcset="
          {{- section.settings.hero_image | image_url: width: 800 -
          }} 800w,
          {{- section.settings.hero_image | image_url: width: 1200 -
          }} 1200w,
          {{- section.settings.hero_image | image_url: width: 1600 -
          }} 1600w,
          {{- section.settings.hero_image | image_url: width: 2000 -
          }} 2000w
        "
        sizes="100vw"
        src="{{ section.settings.hero_image | image_url: width: 1600 }}"
        alt="{{ section.settings.hero_image.alt | default: section.settings.heading | escape }}"
        loading="eager"
        width="1600"
        height="1000"
      >
    {%- else -%}
      <div class="hero-placeholder"></div>
    {%- endif -%}
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-inner">
      {%- if section.settings.badge != blank -%}
        <span class="hero-badge">{{ section.settings.badge | escape }}</span>
      {%- endif -%}

      <h1 id="hero-title" class="hero-heading">{{ section.settings.heading | escape }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="hero-subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      <div class="hero-ctas">
        {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
          <a class="btn btn-primary" href="{{ section.settings.cta_link }}">
            {{ section.settings.cta_text | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_text != blank and section.settings.cta_secondary_link != blank -%}
          <a class="btn btn-outline" href="{{ section.settings.cta_secondary_link }}">
            {{ section.settings.cta_secondary_text | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--surface-2) 0%, var(--bg) 100%);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(24,21,19,0.7) 0%, rgba(24,21,19,0.3) 50%, rgba(24,21,19,0.1) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
  .hero-inner {
    max-width: 680px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    margin-bottom: var(--space-8);
  }
  .hero-heading {
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--white);
    margin: 0 0 var(--space-6);
  }
  @media (max-width: 768px) {
    .hero-heading {
      font-size: var(--text-3xl);
    }
  }
  .hero-subheading {
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.85);
    margin: 0 0 var(--space-10);
    max-width: 480px;
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .hero-subheading {
      font-size: var(--text-base);
    }
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .hero-section:has(.hero-bg img) .hero-overlay {
    background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  }
</style>

<script>
  // Add fade-in animation on load
  (function() {
    const hero = document.querySelector('.hero-section');
    if (hero) {
      hero.style.opacity = '0';
      hero.style.transition = 'opacity 0.8s ease';
      requestAnimationFrame(function() {
        hero.style.opacity = '1';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image",
      "info": "Recommended size: 1600x1000px"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text",
      "default": "PEACHEES FIT · DROP 01"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Soft, sculpted, and made to move beautifully."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading / description",
      "default": "A refined concept store for Peachees Fit—designed with a warmer, cleaner, logo-led identity and a more boutique feel."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA text",
      "default": "Shop the edit"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "View Instagram"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
