{%- comment -%}
  Peachees Lookbook Section
  Masonry-style image grid for campaign/editorial imagery
{%- endcomment -%}

<section class="lookbook-section" id="lookbook" aria-labelledby="lookbook-title">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-label">{{ section.settings.label | escape }}</span>
      {%- endif -%}
      <h2 id="lookbook-title" class="section-heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="section-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    <div class="lookbook-grid">
      {%- liquid
        assign has_images = false
        if section.settings.image_1 != blank or section.settings.image_2 != blank or section.settings.image_3 != blank
          assign has_images = true
        endif
      -%}

      {%- if has_images -%}
        {%- if section.settings.image_1 != blank -%}
          <div class="lookbook-item lookbook-item--wide">
            <img
              srcset="
                {{- section.settings.image_1 | image_url: width: 600 -
                }} 600w,
                {{- section.settings.image_1 | image_url: width: 1000 -
                }} 1000w,
                {{- section.settings.image_1 | image_url: width: 1400 -
                }} 1400w
              "
              sizes="(max-width: 768px) 90vw, (max-width: 1200px) 50vw, 600px"
              src="{{ section.settings.image_1 | image_url: width: 1000 }}"
              alt="{{ section.settings.image_1.alt | default: 'Lookbook image 1' }}"
              loading="lazy"
              class="lookbook-img"
            >
          </div>
        {%- endif -%}
        {%- if section.settings.image_2 != blank -%}
          <div class="lookbook-item lookbook-item--tall">
            <img
              srcset="
                {{- section.settings.image_2 | image_url: width: 600 -
                }} 600w,
                {{- section.settings.image_2 | image_url: width: 1000 -
                }} 1000w
              "
              sizes="(max-width: 768px) 90vw, (max-width: 1200px) 30vw, 400px"
              src="{{ section.settings.image_2 | image_url: width: 800 }}"
              alt="{{ section.settings.image_2.alt | default: 'Lookbook image 2' }}"
              loading="lazy"
              class="lookbook-img"
            >
          </div>
        {%- endif -%}
        {%- if section.settings.image_3 != blank -%}
          <div class="lookbook-item lookbook-item--regular">
            <img
              srcset="
                {{- section.settings.image_3 | image_url: width: 600 -
                }} 600w,
                {{- section.settings.image_3 | image_url: width: 1000 -
                }} 1000w
              "
              sizes="(max-width: 768px) 90vw, (max-width: 1200px) 30vw, 400px"
              src="{{ section.settings.image_3 | image_url: width: 800 }}"
              alt="{{ section.settings.image_3.alt | default: 'Lookbook image 3' }}"
              loading="lazy"
              class="lookbook-img"
            >
          </div>
        {%- endif -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="lookbook-item {% if i == 1 %}lookbook-item--wide{% elsif i == 2 %}lookbook-item--tall{% else %}%"><div class="lookbook-placeholder">
              <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="M21 15l-5-5L5 21" />
              </svg>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .lookbook-section {
    padding: var(--space-20) 0;
  }
  .section-header {
    text-align: center;
    max-width: 520px;
    margin: 0 auto var(--space-12);
  }
  .section-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-4);
  }
  .section-heading {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-4);
  }
  @media (max-width: 768px) {
    .section-heading { font-size: var(--text-xl); }
  }
  .section-desc {
    font-size: var(--text-sm);
    color: var(--muted);
    margin: 0;
  }
  .lookbook-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 768px) {
    .lookbook-grid { grid-template-columns: 1fr; }
  }
  .lookbook-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-2);
  }
  .lookbook-item--wide {
    grid-column: span 2;
  }
  @media (max-width: 768px) {
    .lookbook-item--wide { grid-column: span 1; }
  }
  .lookbook-item--tall {
    aspect-ratio: 3 / 4;
  }
  .lookbook-item--regular {
    aspect-ratio: 4 / 3;
  }
  @media (max-width: 768px) {
    .lookbook-item--regular { aspect-ratio: 3 / 4; }
  }
  .lookbook-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lookbook-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
  }
</style>

{% schema %}
{
  "name": "Lookbook",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Lookbook"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Styled for pilates, errands, and lifts."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "This layout is built to present Peachees Fit as a curated drop, not a crowded catalog, with campaign-style visuals."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Lookbook image 1 (wide)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Lookbook image 2 (tall)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Lookbook image 3"
    }
  ],
  "presets": [
    {
      "name": "Lookbook"
    }
  ]
}
{% endschema %}
